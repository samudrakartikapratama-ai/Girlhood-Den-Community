async function saveVT(){
  const creator=document.getElementById('vt-creator').value.trim();
  const videoUrl=document.getElementById('vt-url').value.trim();
  if(!creator||!videoUrl){toast('Isi username dan link video dulu');return;}
  const productUid=document.getElementById('vt-product').value;
  const p=products.find(x=>x.uid===productUid);
  const tapLink=document.getElementById('vt-tap-link').value.trim();
  const matched=tapLink?products.find(x=>x.link===tapLink||tapLink.includes(x.id)):null;
  const isSat=tapLink?(tapLink.toLowerCase().includes('saturnine')||!!matched):null;
  const entry={id:uid(),creator,date:today(),productName:p?.name||'—',brand:document.getElementById('vt-brand').value||p?.brand||'—',videoUrl,tapLink,isSaturnine:isSat,createdAt:today()};
  setBtnLoading('btn-save-vt',true,'Menyimpan...','Simpan Pengecekan');
  vtLogs.push(entry);
  const ok=await apiPost({action:'saveMeta',sheet:'VTLogs',data:{vtLogs:JSON.stringify(vtLogs)}});
  setBtnLoading('btn-save-vt',false,'Menyimpan...','Simpan Pengecekan');
  if(!ok){vtLogs.pop();toast('⚠️ Gagal simpan. Coba lagi.');return;}
  ['vt-url','vt-creator','vt-tap-link','vt-brand'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('vt-product').value='';
  document.getElementById('vt-result').style.display='none';
  document.getElementById('vt-validation-box').style.display='none';
  renderVT();toast('✓ Pengecekan disimpan!');
}
function renderVT(){
  const search=(document.getElementById('f-search-vt')?.value||'').toLowerCase();
  const valid=document.getElementById('f-valid-vt')?.value||'';
  let filtered=vtLogs.filter(v=>{
    if(search&&!v.creator.toLowerCase().includes(search))return false;
    if(valid==='valid'&&v.isSaturnine!==true)return false;
    if(valid==='invalid'&&v.isSaturnine!==false)return false;
    return true;
  }).sort((a,b)=>b.date.localeCompare(a.date));
  const tbody=document.getElementById('vt-tbody');
  if(!filtered.length){tbody.innerHTML='<tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gray-text)">Belum ada riwayat pengecekan.</td></tr>';return;}
  tbody.innerHTML=filtered.map(v=>{
    const sc=v.isSaturnine===true?'link-valid':v.isSaturnine===false?'link-invalid':'';
    const st=v.isSaturnine===true?'✓ Saturnine':v.isSaturnine===false?'✗ Bukan Saturnine':'— Belum dicek';
    const vl=v.videoUrl?`<a href="${v.videoUrl}" target="_blank" style="color:var(--pink);font-weight:600;font-size:13px">Buka ↗</a>`:'—';
    return`<tr>
      <td style="color:var(--gray-text);font-size:12px">${v.date}</td>
      <td><strong>${v.creator}</strong></td>
      <td>${v.productName}</td>
      <td style="color:var(--gray-text)">${v.brand}</td>
      <td><span class="${sc}" style="font-weight:700">${st}</span></td>
      <td>${vl}</td>
      ${isInternal?`<td><button class="del-btn" onclick="openDelete('vt','${v.id}')">×</button></td>`:'<td></td>'}
    </tr>`;
  }).join('');
}

