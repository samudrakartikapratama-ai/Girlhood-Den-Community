  const ok=await apiPost({action:'saveMeta',sheet:'Campaigns',data:{campaigns:JSON.stringify(campaigns)}});
  setBtnLoading('btn-add-campaign',false,'Menyimpan...','+ Buat Campaign');
  if(!ok){campaigns.pop();toast('⚠️ Gagal simpan campaign. Coba lagi.');return;}
  ['c-name','c-brand','c-gmv','c-comm','c-start','c-end','c-prizes','c-desc'].forEach(id=>document.getElementById(id).value='');
  prev.style.display='none';prev.src='';document.getElementById('c-img-file').value='';
  renderCampaign();toast('✓ Campaign berhasil disimpan!');
}
function renderCampaign(){
  const grid=document.getElementById('campaign-grid');
  if(!campaigns.length){grid.innerHTML='<div class="empty" style="grid-column:1/-1">Belum ada campaign aktif.</div>';return;}
  const sorted=[...campaigns].sort((a,b)=>(b.start||'').localeCompare(a.start||''));
  grid.innerHTML=sorted.map(c=>{
    const dl=daysLeft(c.end);
    const dlClass=dl===null?'':dl>7?'days-active':dl>=0?'days-ending':'days-ended';
    const dlText=dl===null?'':dl>0?dl+' hari lagi':dl===0?'Berakhir hari ini':'Sudah berakhir';
    return`<div class="campaign-card">
      ${c.img?`<img class="campaign-img" src="${c.img}" alt="${c.name}" onerror="this.style.display='none'">`:''}
      <div class="campaign-header"><div class="campaign-brand">${c.brand}</div><div class="campaign-name">${c.name}</div></div>
      <div class="campaign-body">
        ${c.gmv?`<div class="campaign-row"><span class="campaign-label">Target GMV</span><span class="campaign-val">${fRp(c.gmv)}</span></div>`:''}
        ${c.commission?`<div class="campaign-row"><span class="campaign-label">Komisi Creator</span><span class="campaign-val">${c.commission}%</span></div>`:''}
        ${c.start||c.end?`<div class="campaign-row"><span class="campaign-label">Periode</span><span class="campaign-val">${c.start||'—'} → ${c.end||'—'}</span></div>`:''}
        ${dl!==null?`<div class="campaign-row"><span class="campaign-label">Status</span><span class="days-left ${dlClass}">${dlText}</span></div>`:''}
        ${c.prizes?.length?`<div><div class="campaign-label" style="margin-bottom:5px">Hadiah</div><div class="campaign-prizes">${c.prizes.map(prize=>`<span class="badge badge-pink">🎁 ${prize}</span>`).join('')}</div></div>`:''}
        ${c.desc?`<div style="margin-top:10px;font-size:13px;color:var(--gray-text)">${c.desc}</div>`:''}
      </div>
      ${isInternal?`<div class="campaign-actions"><button class="btn btn-danger btn-xs" onclick="openDelete('campaign','${c.id}')">Hapus</button></div>`:''}
    </div>`;
  }).join('');
}

// ═══ RANKING ═══
function processRanking(input){
  const file=input.files[0];if(!file)return;
  document.getElementById('ranking-file-name').textContent='Memproses '+file.name+'...';
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const wb=XLSX.read(e.target.result,{type:'array'}),ws=wb.Sheets[wb.SheetNames[0]],rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
      let headerRow=-1;
      for(let i=0;i<Math.min(5,rows.length);i++){if(rows[i].some(c=>String(c).toLowerCase().includes('creator name'))){headerRow=i;break;}}
      if(headerRow===-1){toast('Format tidak dikenali');document.getElementById('ranking-file-name').textContent='Belum ada file';return;}
      const headers=rows[headerRow].map(h=>String(h).toLowerCase().trim());
      const idx=kws=>headers.findIndex(h=>kws.some(k=>h.includes(k)));
      const iCreator=idx(['creator name']),iShop=idx(['shop name']),iGMV=idx(['affiliate gmv']),iVTGMV=idx(['affiliate video gmv']),iLiveGMV=idx(['affiliate live gmv']),iOrders=idx(['orders']),iViews=idx(['video views']),iLiveViews=idx(['live views']),iComm=idx(['estimated affiliate partner commission']);
      rankingDataAll=[];
      const brands=new Set();
      for(let i=headerRow+1;i<rows.length;i++){
        const row=rows[i],creator=String(row[iCreator]||'').trim();
        if(!creator||creator==='-'||creator.toLowerCase()==='summary')continue;
        const shop=String(row[iShop]||'').trim();if(shop)brands.add(shop);
        const gmv=parseRp(row[iGMV]),liveGMV=parseRp(row[iLiveGMV]),vtGMV=parseRp(row[iVTGMV]);
        rankingDataAll.push({creator,shop,gmv,liveGMV,vtGMV,orders:parseInt(row[iOrders])||0,views:(parseInt(String(row[iViews]||'').replace(/[^0-9]/g,''))||0)+(parseInt(String(row[iLiveViews]||'').replace(/[^0-9]/g,''))||0),commission:parseRp(row[iComm]),contentType:liveGMV>vtGMV?'Live':'Short Video'});
      }
      rankingDataAll.sort((a,b)=>b.gmv-a.gmv);
      rankingData=[...rankingDataAll];
      const brandSel=document.getElementById('f-brand-rank');
      brandSel.innerHTML='<option value="">Semua Brand</option>';
      [...brands].sort().forEach(b=>{const o=document.createElement('option');o.value=b;o.textContent=b;brandSel.appendChild(o);});
      const totalGMV=rankingDataAll.reduce((s,d)=>s+d.gmv,0);
      const totalOrders=rankingDataAll.reduce((s,d)=>s+d.orders,0);
      const totalComm=rankingDataAll.reduce((s,d)=>s+d.commission,0);
      document.getElementById('ranking-metrics').style.display='grid';
      document.getElementById('ranking-metrics').innerHTML=`
        <div class="metric"><div class="metric-label">Total GMV</div><div class="metric-value">${fRp(totalGMV)}</div></div>
        <div class="metric"><div class="metric-label">Total Creator</div><div class="metric-value">${rankingDataAll.length}</div></div>
        <div class="metric"><div class="metric-label">Total Orders</div><div class="metric-value">${totalOrders.toLocaleString('id-ID')}</div></div>
        <div class="metric"><div class="metric-label">Est. Komisi</div><div class="metric-value">${fRp(totalComm)}</div></div>
        <div class="metric"><div class="metric-label">Brand Aktif</div><div class="metric-value">${brands.size}</div></div>`;
      document.getElementById('ranking-table-wrap').style.display='block';
      document.getElementById('ranking-file-name').textContent=file.name+' ✓';
      renderRanking();
      toast('✓ Ranking '+rankingDataAll.length+' creator berhasil dibuat!');
    }catch(err){toast('Gagal baca file: '+err.message);document.getElementById('ranking-file-name').textContent='Belum ada file';}
  };
  reader.onerror=()=>{toast('Gagal membaca file');};
  reader.readAsArrayBuffer(file);
}
function filterRanking(){
  const search=(document.getElementById('f-search-rank').value||'').toLowerCase();
  const brand=document.getElementById('f-brand-rank').value;
  const content=document.getElementById('f-content-rank').value;
  rankingData=rankingDataAll.filter(d=>{
    if(search&&!d.creator.toLowerCase().includes(search))return false;
    if(brand&&d.shop!==brand)return false;
    if(content&&d.contentType!==content)return false;
    return true;
  });
  renderRanking();
}
function renderRanking(){
  const tbody=document.getElementById('ranking-tbody');
  if(!rankingData.length){tbody.innerHTML='<tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--gray-text)">Tidak ada data.</td></tr>';return;}
  const n=rankingData.length;
  tbody.innerHTML=rankingData.map((d,i)=>{
    const rank=i+1,isTop=i<10,isBot=i>=n-10&&n>10;
    const rowClass=isTop?'rank-top':isBot?'rank-bottom':'';
    const rankIcon=rank===1?'🥇':rank===2?'🥈':rank===3?'🥉':rank;
    const ct=d.liveGMV>d.vtGMV?'<span class="badge badge-active">Live</span>':'<span class="badge badge-cat">Video</span>';
    return`<tr class="${rowClass}">
      <td style="font-weight:700;font-size:15px">${rankIcon}</td>
      <td><strong>${d.creator}</strong></td>
      <td style="color:var(--gray-text);font-size:12px">${d.shop}</td>
      <td><strong>${fRp(d.gmv)}</strong></td>
      <td style="color:var(--teal)">${fRp(d.liveGMV)}</td>
      <td style="color:var(--blue)">${fRp(d.vtGMV)}</td>
      <td>${d.orders.toLocaleString('id-ID')}</td>
      <td>${ct}</td>
    </tr>`;
  }).join('');
}

// ═══ BACKUP / RESTORE ═══
function exportBackup(){
  const data={products,campaigns,vtLogs,exportedAt:new Date().toISOString()};
  const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='girlhood_den_backup_'+today()+'.json';a.click();
  toast('✓ Backup berhasil didownload!');
}
async function importBackup(input){
  const file=input.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=async e=>{
    try{
      const data=JSON.parse(e.target.result);
      let success=[],fail=[];
      if(Array.isArray(data.products)&&data.products.length){
        const ex=new Set(products.map(p=>p.uid));
        const newOnes=data.products.filter(p=>!ex.has(p.uid));
        for(const p of newOnes){
          const ok=await apiPost({action:'save',sheet:'Products',product:p});
          if(ok)products.push(p);else fail.push(p.name);
        }
        if(newOnes.length)success.push(newOnes.length+' produk');
      }
      if(Array.isArray(data.campaigns)&&data.campaigns.length){
        const ex=new Set(campaigns.map(c=>c.id));
        const newOnes=data.campaigns.filter(c=>!ex.has(c.id));
        if(newOnes.length){
          campaigns=[...campaigns,...newOnes];
          await apiPost({action:'saveMeta',sheet:'Campaigns',data:{campaigns:JSON.stringify(campaigns)}});
          success.push('campaign');
        }
      }
      renderPalette();renderCampaign();
      input.value='';
      if(fail.length)toast('⚠️ Sebagian gagal: '+fail.join(', '),5000);
      else toast('✓ Restore berhasil: '+success.join(', '));
    }catch(e){toast('File tidak valid');input.value='';}
  };
  reader.readAsText(file);
}

// ═══ INIT ═══
async function initApp(){
  const loadingText=document.getElementById('loading-text');
  const banner=document.getElementById('status-banner');
  const MAX_WAIT=15000;
  
  // Safety timeout — halaman PASTI muncul dalam 15 detik
  const safetyTimer=setTimeout(()=>{
    document.getElementById('loading-overlay').style.display='none';
    banner.textContent='⚠️ Koneksi ke server lambat. Beberapa data mungkin belum termuat. Coba refresh.';
    banner.className='status-banner status-err';
    document.getElementById('login-overlay').style.display='flex';
  },MAX_WAIT);

  try{
    // Load products
    loadingText.textContent='Memuat produk...';
    const rawProducts=await Promise.race([
      apiGet('Products'),
      new Promise((_,rej)=>setTimeout(()=>rej(new Error('timeout')),12000))
    ]);
    products=Array.isArray(rawProducts)?rawProducts:[];

    // Load campaigns & VT logs from Meta sheet
    loadingText.textContent='Memuat campaign & data lainnya...';
    const metaRes=await Promise.race([
      apiGet('Meta'),
      new Promise((_,rej)=>setTimeout(()=>rej(new Error('timeout')),12000))
    ]);
    
    if(Array.isArray(metaRes)){
      const meta={};metaRes.forEach(r=>{if(r.key&&r.value)meta[r.key]=r.value;});
      try{if(meta.campaigns)campaigns=JSON.parse(meta.campaigns);}catch(e){campaigns=[];}
      try{if(meta.vtLogs)vtLogs=JSON.parse(meta.vtLogs);}catch(e){vtLogs=[];}
    }

    clearTimeout(safetyTimer);
    storageOK=true;
    banner.textContent='✓ Terhubung ke server — data real-time dari Google Sheets';
    banner.className='status-banner status-ok';
    setTimeout(()=>banner.style.display='none',3000);
  }catch(e){
    clearTimeout(safetyTimer);
    banner.textContent='⚠️ Gagal konek ke server. Tampil dalam mode offline — data mungkin tidak terbaru.';
    banner.className='status-banner status-err';
  }

  renderPalette();renderCampaign();
  document.getElementById('loading-overlay').style.display='none';
  document.getElementById('login-overlay').style.display='flex';
}

initApp();
</script>
