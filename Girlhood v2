function renderPalette(){
  const search=document.getElementById('f-search-palette').value.toLowerCase();
  const cat=document.getElementById('f-cat-palette').value;
  const status=document.getElementById('f-status-palette').value||'active';
  let filtered=products.filter(p=>{
    if(search&&!p.name.toLowerCase().includes(search)&&!p.brand.toLowerCase().includes(search))return false;
    if(cat&&p.category!==cat)return false;
    if(status&&p.status!==status)return false;
    return true;
  });
  document.getElementById('palette-count').textContent=filtered.length+' produk';
  const active=products.filter(p=>p.status==='active').length;
  const brands=new Set(products.map(p=>p.brand)).size;
  document.getElementById('palette-metrics').innerHTML=`
    <div class="metric"><div class="metric-label">Total Produk</div><div class="metric-value">${products.length}</div></div>
    <div class="metric"><div class="metric-label">Aktif</div><div class="metric-value">${active}</div></div>
    <div class="metric"><div class="metric-label">Brand</div><div class="metric-value">${brands}</div></div>
    <div class="metric"><div class="metric-label">Nonaktif</div><div class="metric-value">${products.length-active}</div></div>`;
  const grid=document.getElementById('palette-grid');
  if(!filtered.length){grid.innerHTML='<div class="empty" style="grid-column:1/-1">Belum ada produk aktif.</div>';return;}
  grid.innerHTML=filtered.map(p=>`
    <div class="product-card">
      ${p.img?`<img class="product-img" src="${p.img}" alt="${p.name}" onerror="this.outerHTML='<div class=product-img-placeholder>🧴</div>'">`:'<div class="product-img-placeholder">🧴</div>'}
      <div class="product-body">
        <div class="product-brand">${p.brand}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-id">ID: ${p.id}</div>
        <div class="product-meta">
          <span class="badge badge-cat">${p.category||'—'}</span>
          ${p.commission?`<span class="badge badge-comm">Komisi ${p.commission}%</span>`:''}
          ${p.price?`<span class="badge badge-pink">${fRp(p.price)}</span>`:''}
          <span class="badge ${p.status==='active'?'badge-active':'badge-inactive'}">${p.status==='active'?'Aktif':'Nonaktif'}</span>
        </div>
        ${p.note?`<div style="font-size:11px;color:var(--gray-text);margin-bottom:8px;font-style:italic">${p.note}</div>`:''}
        <div class="product-actions">
          <button class="copy-btn" onclick="copyVal('${p.uid}','link',this)">Copy Link</button>
          <button class="copy-btn" onclick="copyVal('${p.uid}','id',this)">Copy ID</button>
          ${isInternal?`<button class="del-btn" onclick="openDelete('product','${p.uid}')">×</button>`:''}
        </div>
      </div>
    </div>`).join('');
}
function copyVal(uid,type,btn){
  const p=products.find(x=>x.uid===uid);if(!p)return;
  navigator.clipboard.writeText(type==='link'?p.link:p.id).then(()=>{
    const orig=btn.textContent;
    btn.textContent=type==='link'?'✓ Link Disalin!':'✓ ID Disalin!';
    btn.classList.add('copied');
    setTimeout(()=>{btn.textContent=orig;btn.classList.remove('copied');},2000);
  });
}

