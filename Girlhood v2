function parseVTUrl(){
  const url=document.getElementById('vt-url').value.trim();
  const result=document.getElementById('vt-result');
  const match=url.match(/tiktok\.com\/@([^/?]+)\/video\/(\d+)/);
  if(match){
    document.getElementById('vt-username').textContent='@'+match[1];
    document.getElementById('vt-videoid').textContent=match[2];
    document.getElementById('vt-creator').value='@'+match[1];
    result.style.display='block';
  }else if(url.length>10){
    document.getElementById('vt-username').textContent='Tidak terdeteksi';
    document.getElementById('vt-videoid').textContent='—';
    result.style.display='block';
  }else{result.style.display='none';}
}
function validateTAPLink(){
  const link=document.getElementById('vt-tap-link').value.trim();
  const box=document.getElementById('vt-validation-box');
  const msg=document.getElementById('vt-validation-msg');
  if(!link){box.style.display='none';return;}
  box.style.display='block';
  const matched=products.find(p=>p.link===link||link.includes(p.id));
  const isSat=link.toLowerCase().includes('saturnine')||!!matched;
  if(matched){
    msg.style.background='var(--green-light)';msg.style.color='var(--green)';
    msg.textContent='✓ Link Saturnine terdeteksi — '+matched.brand+' '+matched.name;
    document.getElementById('vt-product').value=matched.uid;
    document.getElementById('vt-brand').value=matched.brand;
  }else if(isSat){
    msg.style.background='var(--green-light)';msg.style.color='var(--green)';
    msg.textContent='✓ Link Saturnine terdeteksi';
  }else{
    msg.style.background='var(--red-light)';msg.style.color='var(--red)';
    msg.textContent='✗ Link ini BUKAN dari Saturnine — tidak ditemukan di palette';
  }
}
