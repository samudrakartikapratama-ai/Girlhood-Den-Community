// ═══ API ═══
async function apiGet(sheet){
  const res=await fetch(SCRIPT_URL+'?sheet='+sheet,{method:'GET'});
  const data=await res.json();
  return data.ok?data.data:[];
}
async function apiPost(payload){
  try{
    const res=await fetch(SCRIPT_URL,{method:'POST',body:JSON.stringify(payload)});
    const data=await res.json();
    return data.ok===true;
  }catch(e){return false;}
}

// ═══ UTILS ═══
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2);}
function fRp(n){n=parseInt(n||0);if(n>=1000000000)return'Rp'+(n/1e9).toFixed(1)+'M';if(n>=1000000)return'Rp'+(n/1e6).toFixed(1)+'jt';if(n>=1000)return'Rp'+(n/1e3).toFixed(0)+'rb';return'Rp'+n;}
function today(){return new Date().toISOString().split('T')[0];}
function daysLeft(end){if(!end)return null;return Math.ceil((new Date(end)-new Date())/86400000);}
function parseRp(v){return parseInt(String(v||0).replace(/[^0-9]/g,''))||0;}
function toast(msg,d=3500){const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');clearTimeout(window._tt);window._tt=setTimeout(()=>el.classList.remove('show'),d);}
function setBtnLoading(id,loading,loadText,normalText){const b=document.getElementById(id);if(!b)return;b.disabled=loading;b.textContent=loading?loadText:normalText;}
function compressImage(file,cb){
  const r=new FileReader();
  r.onload=e=>{
    const img=new Image();
    img.onload=()=>{
      const MAX=800;let w=img.width,h=img.height;
      if(w>h&&w>MAX){h=Math.round(h*MAX/w);w=MAX;}else if(h>MAX){w=Math.round(w*MAX/h);h=MAX;}
      const c=document.createElement('canvas');c.width=w;c.height=h;
      c.getContext('2d').drawImage(img,0,0,w,h);
      cb(c.toDataURL('image/jpeg',0.82));
    };
    img.onerror=()=>{toast('Gagal membaca gambar');cb(null);};
    img.src=e.target.result;
  };
  r.onerror=()=>{toast('Gagal baca file');cb(null);};
  r.readAsDataURL(file);
}

