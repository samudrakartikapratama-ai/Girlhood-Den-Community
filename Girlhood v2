<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Girlhood Den — Creator Hub</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --pink:#E8185A;--pink-light:#FFD6E7;--pink-pale:#FFF0F6;--pink-mid:#F472A8;
  --dark:#2C1A22;--gray:#FBF3F7;--gray-mid:#E8D5DF;--gray-text:#9A7285;
  --white:#FFFFFF;--teal:#1D9E75;--teal-light:#E1F5EE;--teal-mid:#9FE1CB;
  --amber:#FAEEDA;--amber-dark:#854F0B;--red:#A32D2D;--red-light:#FCEBEB;
  --blue-light:#E6F1FB;--blue:#185FA5;--green:#3B6D11;--green-light:#EAF3DE;
}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:var(--gray);color:var(--dark);min-height:100vh;font-size:15px}
body::before{content:"";position:fixed;inset:0;background:radial-gradient(circle at 10% 20%,rgba(232,24,90,.05) 0%,transparent 50%),radial-gradient(circle at 90% 80%,rgba(244,114,168,.07) 0%,transparent 50%);pointer-events:none;z-index:0}

/* LOADING */
.loading-overlay{position:fixed;inset:0;background:var(--pink-pale);z-index:999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px}
.loading-logo{width:140px;animation:pulse 1.5s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.7;transform:scale(.97)}}
.loading-text{font-size:14px;color:var(--pink);font-weight:600}
.loading-spinner{width:32px;height:32px;border:3px solid var(--pink-light);border-top-color:var(--pink);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* STATUS BANNER */
.status-banner{padding:10px 2rem;font-size:13px;font-weight:600;text-align:center;display:none}
.status-ok{background:var(--green-light);color:var(--green);display:block}
.status-err{background:var(--red-light);color:var(--red);display:block}

/* NAV */
.nav{background:var(--white);border-bottom:2px solid var(--pink-light);padding:0 2rem;display:flex;align-items:center;position:sticky;top:0;z-index:100;box-shadow:0 2px 16px rgba(232,24,90,.08)}
.nav-logo{height:38px;object-fit:contain;margin-right:1.5rem;padding:4px 0}
.nav-tab{padding:1.1rem 1.3rem;font-size:14px;cursor:pointer;color:var(--gray-text);border-bottom:2.5px solid transparent;margin-bottom:-2px;transition:all .15s;white-space:nowrap;font-weight:500}
.nav-tab:hover{color:var(--pink)}.nav-tab.active{color:var(--pink);border-bottom-color:var(--pink);font-weight:700}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:10px}
.mode-badge{font-size:12px;padding:5px 14px;border-radius:99px;font-weight:700;cursor:pointer;border:none;transition:all .15s}
.mode-internal{background:var(--pink);color:var(--white)}.mode-public{background:var(--pink-light);color:var(--pink)}

/* LAYOUT */
.container{max-width:1200px;margin:0 auto;padding:2rem;position:relative;z-index:1}
.page{display:none}.page.active{display:block}
.page-header{margin-bottom:1.5rem;display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:8px}
.page-title{font-size:24px;font-weight:700;color:var(--dark)}
.page-sub{font-size:14px;color:var(--gray-text);margin-top:3px}

/* METRICS */
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:1.5rem}
.metric{background:var(--white);border-radius:12px;padding:14px 16px;border:1.5px solid var(--pink-light)}
.metric-label{font-size:11px;color:var(--gray-text);margin-bottom:5px;text-transform:uppercase;letter-spacing:.04em;font-weight:600}
.metric-value{font-size:22px;font-weight:700;color:var(--dark)}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:10px;font-size:14px;cursor:pointer;border:none;font-weight:600;transition:all .15s}
.btn-primary{background:var(--pink);color:var(--white)}.btn-primary:hover{background:#C4144E;transform:translateY(-1px)}
.btn-secondary{background:var(--white);color:var(--dark);border:1.5px solid var(--gray-mid)}.btn-secondary:hover{background:var(--gray)}
.btn-danger{background:var(--red-light);color:var(--red);border:1px solid #F7C1C1}
.btn-sm{padding:6px 12px;font-size:12px}.btn-xs{padding:4px 8px;font-size:11px}
.btn:disabled{opacity:.6;cursor:not-allowed;transform:none!important}

/* FORM */
.form-card{background:var(--white);border:1.5px solid var(--pink-light);border-radius:16px;padding:1.5rem;margin-bottom:1.5rem;box-shadow:0 2px 12px rgba(232,24,90,.06);position:relative;overflow:hidden}
.form-card::before{content:"";position:absolute;top:0;right:0;width:160px;height:160px;background:radial-gradient(circle,var(--pink-light) 1.5px,transparent 1.5px) 0 0/18px 18px;opacity:.4;pointer-events:none}
.form-title{font-size:12px;font-weight:700;color:var(--pink);margin-bottom:14px;text-transform:uppercase;letter-spacing:.08em}
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px;margin-bottom:12px}
.form-group{display:flex;flex-direction:column;gap:5px}
.form-group label{font-size:11px;color:var(--gray-text);font-weight:700;text-transform:uppercase;letter-spacing:.03em}
.form-group input,.form-group select,.form-group textarea{font-size:14px;padding:9px 12px;border:1.5px solid var(--gray-mid);border-radius:9px;background:var(--white);color:var(--dark);outline:none;transition:border .15s}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--pink)}
.form-group textarea{resize:vertical;min-height:70px}
.form-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap}

/* PRODUCT PALETTE */
.palette-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:14px;margin-bottom:1.5rem}
.product-card{background:var(--white);border:1.5px solid var(--pink-light);border-radius:14px;overflow:hidden;transition:box-shadow .2s,transform .2s}
.product-card:hover{box-shadow:0 6px 24px rgba(232,24,90,.14);transform:translateY(-3px)}
.product-img{width:100%;height:150px;object-fit:cover;display:block}
.product-img-placeholder{width:100%;height:150px;background:linear-gradient(135deg,var(--pink-pale),var(--pink-light));display:flex;align-items:center;justify-content:center;font-size:40px}
.product-body{padding:12px}
.product-brand{font-size:11px;color:var(--pink);font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.product-name{font-size:14px;font-weight:600;color:var(--dark);margin-bottom:5px;line-height:1.3}
.product-id{font-size:10px;color:var(--gray-text);font-family:monospace;margin-bottom:8px;word-break:break-all}
.product-meta{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:10px}
.badge{display:inline-block;font-size:11px;padding:3px 8px;border-radius:99px;font-weight:600;white-space:nowrap}
.badge-comm{background:var(--teal-light);color:#0F6E56}
.badge-cat{background:var(--blue-light);color:var(--blue)}
.badge-active{background:var(--green-light);color:var(--green)}
.badge-inactive{background:var(--gray);color:var(--gray-text)}
.badge-pink{background:var(--pink-light);color:var(--pink)}
.product-actions{display:flex;gap:5px;align-items:center}
.copy-btn{flex:1;background:var(--pink-pale);color:var(--pink);border:1px solid var(--pink-light);border-radius:7px;padding:7px 6px;font-size:11px;cursor:pointer;transition:all .15s;text-align:center;font-weight:700}
.copy-btn:hover{background:var(--pink-light)}.copy-btn.copied{background:var(--teal-light);color:var(--teal);border-color:var(--teal-mid)}
.del-btn{background:none;border:none;cursor:pointer;color:var(--gray-text);font-size:18px;padding:4px 6px;border-radius:7px}
.del-btn:hover{color:var(--red);background:var(--red-light)}

/* INTERNAL ONLY */
.internal-only{display:none}
body.internal-mode .internal-only{display:block}
.public-note{background:var(--pink-pale);border:1.5px solid var(--pink-light);border-radius:12px;padding:12px 16px;font-size:14px;color:var(--gray-text);margin-bottom:1rem;display:none}
body:not(.internal-mode) .public-note{display:block}

/* FILTER BAR */
.filter-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:1rem;align-items:center}
.filter-bar input,.filter-bar select{font-size:13px;padding:8px 12px;border:1.5px solid var(--gray-mid);border-radius:9px;background:var(--white);color:var(--dark)}
.filter-bar input{min-width:200px}
.result-count{font-size:13px;color:var(--gray-text);margin-left:auto}

/* CAMPAIGN */
.campaign-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px;margin-bottom:1.5rem}
.campaign-card{background:var(--white);border:1.5px solid var(--pink-light);border-radius:16px;overflow:hidden;transition:box-shadow .2s}
.campaign-card:hover{box-shadow:0 6px 24px rgba(232,24,90,.12)}
.campaign-header{background:linear-gradient(135deg,var(--pink),var(--pink-mid));padding:16px;color:var(--white)}
.campaign-brand{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;opacity:.85;margin-bottom:4px}
.campaign-name{font-size:17px;font-weight:700;line-height:1.2}
.campaign-body{padding:16px}
.campaign-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:9px;font-size:14px}
.campaign-label{color:var(--gray-text);font-weight:700;font-size:11px;text-transform:uppercase}
.campaign-val{color:var(--dark);font-weight:600}
.campaign-prizes{display:flex;gap:5px;flex-wrap:wrap;margin-top:5px}
.campaign-img{width:100%;height:130px;object-fit:cover;display:block}
.campaign-actions{padding:10px 16px;border-top:1px solid var(--gray);display:flex;gap:6px}
.days-left{font-size:11px;padding:3px 9px;border-radius:99px;font-weight:700}
.days-active{background:var(--green-light);color:var(--green)}
.days-ending{background:var(--amber);color:var(--amber-dark)}
.days-ended{background:var(--red-light);color:var(--red)}

/* RANKING */
.table-wrap{background:var(--white);border:1.5px solid var(--pink-light);border-radius:16px;overflow:hidden;margin-bottom:1.5rem}
.table-scroll{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:14px}
thead tr{background:var(--pink-pale)}
th{padding:12px 14px;text-align:left;font-weight:700;color:var(--pink);font-size:11px;border-bottom:1.5px solid var(--pink-light);white-space:nowrap;text-transform:uppercase;letter-spacing:.04em}
td{padding:11px 14px;color:var(--dark);border-bottom:1px solid var(--gray)}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--pink-pale)}
.rank-top td{background:#F0FFF4!important}.rank-bottom td{background:#FFF5F5!important}

/* LOGIN */
.login-overlay{position:fixed;inset:0;background:rgba(232,24,90,.12);backdrop-filter:blur(10px);z-index:500;display:flex;align-items:center;justify-content:center}
.login-box{background:var(--white);border-radius:24px;padding:2.5rem;width:90%;max-width:380px;text-align:center;box-shadow:0 24px 64px rgba(232,24,90,.2)}
.login-logo{width:130px;margin:0 auto 1.5rem;display:block}
.login-title{font-size:22px;font-weight:700;color:var(--dark);margin-bottom:6px}
.login-sub{font-size:14px;color:var(--gray-text);margin-bottom:1.5rem}
.login-input{width:100%;font-size:20px;padding:13px;border:2px solid var(--pink-light);border-radius:12px;text-align:center;letter-spacing:6px;color:var(--dark);margin-bottom:12px;outline:none;transition:border .15s}
.login-input:focus{border-color:var(--pink)}
.login-err{font-size:13px;color:var(--red);margin-bottom:10px;display:none;font-weight:600}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(44,26,34,.5);z-index:300;display:none;align-items:center;justify-content:center}
.modal-overlay.show{display:flex}
.modal{background:var(--white);border-radius:18px;padding:1.75rem;width:90%;max-width:500px}
.modal-title{font-size:18px;font-weight:700;margin-bottom:1rem;color:var(--dark)}
.modal-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:1rem}

/* TOAST */
.toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--dark);color:var(--white);padding:11px 18px;border-radius:12px;font-size:14px;opacity:0;transition:opacity .3s;pointer-events:none;z-index:999;font-weight:600;max-width:320px}
.toast.show{opacity:1}

.empty{text-align:center;padding:3rem;color:var(--gray-text);font-size:14px}
.vt-input-area{background:var(--white);border:1.5px solid var(--pink-light);border-radius:16px;padding:1.5rem;margin-bottom:1.5rem;position:relative;overflow:hidden}
.vt-input-area::before{content:"";position:absolute;top:0;right:0;width:160px;height:160px;background:radial-gradient(circle,var(--pink-light) 1.5px,transparent 1.5px) 0 0/18px 18px;opacity:.4;pointer-events:none}
.vt-url-row{display:flex;gap:8px;margin-bottom:14px}
.vt-url-row input{flex:1;font-size:14px;padding:10px 14px;border:1.5px solid var(--gray-mid);border-radius:9px;background:var(--white);color:var(--dark);outline:none;transition:border .15s}
.vt-url-row input:focus{border-color:var(--pink)}
.vt-result-box{background:var(--pink-pale);border:1.5px solid var(--pink-light);border-radius:12px;padding:14px;margin-bottom:14px;display:none}
.vt-result-row{display:flex;gap:10px;align-items:center;margin-bottom:6px;font-size:14px}
.vt-result-label{color:var(--gray-text);width:120px;flex-shrink:0;font-size:11px;text-transform:uppercase;font-weight:700}
.vt-result-val{color:var(--dark);font-weight:600}
.link-valid{color:var(--green);font-weight:700}
.link-invalid{color:var(--red);font-weight:700}

@media(max-width:640px){.palette-grid,.campaign-grid{grid-template-columns:1fr}.metrics{grid-template-columns:repeat(2,1fr)}.nav-tab{padding:.8rem .7rem;font-size:12px}}
</style>
</head>
<body>

<!-- LOADING -->
<div class="loading-overlay" id="loading-overlay">
  <img class="loading-logo" src="data:image/jpeg;base64," alt="Girlhood Den">
  <div class="loading-spinner"></div>
  <div class="loading-text" id="loading-text">Memuat data...</div>
</div>

<!-- STATUS BANNER -->
<div class="status-banner" id="status-banner"></div>

<!-- LOGIN -->
<div class="login-overlay" id="login-overlay" style="display:none">
  <div class="login-box">
    <img class="login-logo" src="data:image/jpeg;base64," alt="Girlhood Den">
    <div class="login-title">Girlhood Den Hub</div>
    <div class="login-sub">Masukkan PIN untuk akses internal</div>
    <input class="login-input" type="password" id="pin-input" placeholder="••••" maxlength="6" onkeydown="if(event.key==='Enter')checkPin()">
    <div class="login-err" id="pin-err">PIN salah. Coba lagi.</div>
    <button class="btn btn-primary" style="width:100%;justify-content:center;margin-bottom:10px;font-size:15px" onclick="checkPin()">🔐 Masuk sebagai Internal</button>
    <button class="btn btn-secondary" style="width:100%;justify-content:center;font-size:15px" onclick="enterPublic()">👀 Lihat sebagai Creator</button>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- MODAL DELETE -->
<div class="modal-overlay" id="modal-delete">
  <div class="modal">
    <div class="modal-title">Hapus item ini?</div>
    <p style="font-size:14px;color:var(--gray-text);margin-bottom:4px">Data akan dihapus permanen dari server.</p>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('modal-delete')">Batal</button>
      <button class="btn btn-danger" id="btn-confirm-delete" onclick="confirmDelete()">Hapus</button>
    </div>
  </div>
</div>

<!-- NAV -->
<nav class="nav">
  <img class="nav-logo" src="data:image/jpeg;base64," alt="Girlhood Den">
  <div class="nav-tab active" onclick="switchPage('palette')">Product Palette</div>
  <div class="nav-tab" onclick="switchPage('vt')">VT Checker</div>
  <div class="nav-tab" onclick="switchPage('campaign')">Campaign</div>
  <div class="nav-tab" onclick="switchPage('ranking')">Ranking GMV</div>
  <div class="nav-right">
    <span class="mode-badge mode-public" id="mode-badge" onclick="toggleMode()">👤 View Only</span>
  </div>
</nav>

<!-- PRODUCT PALETTE -->
<div class="page active" id="page-palette">
<div class="container">
  <div class="page-header">
    <div><div class="page-title">Product Palette 💄</div><div class="page-sub">Semua produk aktif — copy link affiliate atau Product ID langsung</div></div>
    <div class="internal-only" style="display:flex;gap:8px">
      <button class="btn btn-secondary btn-sm" onclick="exportBackup()">↓ Backup JSON</button>
      <label class="btn btn-secondary btn-sm" style="cursor:pointer">↑ Restore<input type="file" accept=".json" style="display:none" onchange="importBackup(this)"></label>
    </div>
  </div>
  <div class="public-note">👀 Kamu dalam mode <strong>View Only</strong> — bisa lihat produk dan copy link affiliate. Hubungi admin untuk akses penuh.</div>
  <div class="metrics" id="palette-metrics"></div>
  <div class="form-card internal-only">
    <div class="form-title">+ Tambah Produk Baru</div>
    <div class="form-grid">
      <div class="form-group"><label>Brand *</label><input id="p-brand" placeholder="contoh: KIME Skincare"></div>
      <div class="form-group"><label>Nama Produk *</label><input id="p-name" placeholder="contoh: Luminizing Jeju Soap"></div>
      <div class="form-group"><label>Product ID *</label><input id="p-id" placeholder="contoh: 1729427766722726591"></div>
      <div class="form-group"><label>Link Affiliate TAP *</label><input id="p-link" placeholder="https://..."></div>
      <div class="form-group"><label>Kategori</label><select id="p-cat"><option>Skincare</option><option>Bodycare</option><option>Makeup</option><option>Haircare</option><option>Fragrance</option><option>Supplement</option><option>Lainnya</option></select></div>
      <div class="form-group"><label>Komisi (%)</label><input id="p-comm" type="number" placeholder="5" min="0" max="100"></div>
      <div class="form-group"><label>Harga (Rp)</label><input id="p-price" type="number" placeholder="25000"></div>
      <div class="form-group"><label>Status</label><select id="p-status"><option value="active">Aktif</option><option value="inactive">Tidak Aktif</option></select></div>
    </div>
    <div class="form-group" style="margin-bottom:10px">
      <label>Foto Produk (upload dari komputer)</label>
      <input type="file" id="p-img-file" accept="image/jpeg,image/png,image/webp" style="font-size:13px;padding:6px;border:1.5px solid var(--gray-mid);border-radius:9px" onchange="previewImg(this)">
      <img id="p-img-preview" src="" alt="" style="display:none;max-height:100px;margin-top:8px;border-radius:8px;border:1.5px solid var(--gray-mid)">
    </div>
    <div class="form-group" style="margin-bottom:12px"><label>Catatan</label><textarea id="p-note" placeholder="info tambahan, syarat sample, dll"></textarea></div>
    <div class="form-actions"><button class="btn btn-primary" id="btn-add-product" onclick="addProduct()">+ Tambah Produk</button></div>
  </div>
  <div class="filter-bar">
    <input type="text" id="f-search-palette" placeholder="Cari produk atau brand..." oninput="renderPalette()">
    <select id="f-cat-palette" onchange="renderPalette()"><option value="">Semua Kategori</option><option>Skincare</option><option>Bodycare</option><option>Makeup</option><option>Haircare</option><option>Fragrance</option><option>Lainnya</option></select>
    <select id="f-status-palette" onchange="renderPalette()"><option value="active">Aktif</option><option value="">Semua</option><option value="inactive">Nonaktif</option></select>
    <span class="result-count" id="palette-count"></span>
  </div>
  <div class="palette-grid" id="palette-grid"></div>
</div>
</div>

<!-- VT CHECKER -->
<div class="page" id="page-vt">
<div class="container">
  <div class="page-header">
    <div><div class="page-title">VT Checker ✅</div><div class="page-sub">Cek apakah video kamu menggunakan link affiliate Saturnine</div></div>
  </div>
  <div class="vt-input-area">
    <div class="form-title">Cek Video Kamu</div>
    <div class="vt-url-row">
      <input id="vt-url" placeholder="Paste link TikTok video: https://www.tiktok.com/@username/video/..." oninput="parseVTUrl()">
      <button class="btn btn-primary" onclick="parseVTUrl()">Cek</button>
    </div>
    <div class="vt-result-box" id="vt-result">
      <div class="vt-result-row"><span class="vt-result-label">Username</span><span class="vt-result-val" id="vt-username">—</span></div>
      <div class="vt-result-row"><span class="vt-result-label">Video ID</span><span class="vt-result-val" id="vt-videoid">—</span></div>
    </div>
    <div class="form-grid">
      <div class="form-group"><label>Username Creator</label><input id="vt-creator" placeholder="@username (auto-detect)"></div>
      <div class="form-group"><label>Produk yang digunakan</label><select id="vt-product" onchange="autoFillVTBrand()"><option value="">Pilih dari palette...</option></select></div>
      <div class="form-group"><label>Brand</label><input id="vt-brand" placeholder="Auto-fill" readonly style="background:var(--gray)"></div>
      <div class="form-group"><label>Link TAP yang digunakan</label><input id="vt-tap-link" placeholder="Link affiliate di showcase video" oninput="validateTAPLink()"></div>
    </div>
    <div id="vt-validation-box" style="margin-bottom:14px;display:none">
      <div style="font-size:14px;padding:11px 16px;border-radius:10px;font-weight:700" id="vt-validation-msg"></div>
    </div>
    <p style="font-size:13px;color:var(--gray-text);margin-bottom:14px">💡 Paste link affiliate yang kamu pasang di showcase video untuk dicek apakah dari Saturnine atau bukan.</p>
    <button class="btn btn-primary" id="btn-save-vt" onclick="saveVT()">Simpan Pengecekan</button>
